{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SD Family Taxi AI Router Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent",
    "confidence",
    "extracted_fields",
    "reply",
    "required_action",
    "requires_manager",
    "next_state"
  ],
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "registration",
        "existing_driver_support",
        "human_operator",
        "payout_support",
        "tariff_support",
        "yandex_problem",
        "application_status",
        "driver_update_request",
        "smz_request",
        "blocking_priority_support",
        "rental_car_question",
        "courier_registration",
        "faq",
        "unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "extracted_fields": {
      "type": "object",
      "additionalProperties": true
    },
    "reply": {
      "type": "string"
    },
    "required_action": {
      "type": "string"
    },
    "requires_manager": {
      "type": "boolean"
    },
    "next_state": {
      "type": ["string", "null"]
    },
    "support_topic": {
      "type": ["string", "null"]
    },
    "reasoning_summary": {
      "type": ["string", "null"]
    }
  }
}

